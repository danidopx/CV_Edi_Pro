{
  "manifest_version": 3,
  "name": "Edi Pro - Captura de Vagas",
  "version": "1.0.1",
  "description": "Capture vagas para ajustar o seu currículo com Inteligência Artificial.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://curriculo-edi.vercel.app/*",
    "https://*.vercel.app/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "128": "icon.png"
    }
  },
  "icons": {
    "128": "icon.png",
    "192": "icon-192.png",
    "512": "icon-512.png"
  }
}
