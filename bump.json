const fs = require('fs');
const path = require('path');

// 1. Caminhos dos arquivos
const pkgPath = path.join(__dirname, 'package.json');
const indexPath = path.join(__dirname, 'public', 'index.html');

// 2. Ler e atualizar o package.json
let pkg = JSON.parse(fs.readFileSync(pkgPath, 'utf8'));
let [major, minor, patch
] = pkg.version.split('.');
patch = parseInt(patch) + 1; // Soma +1 na última casa da versão
const novaVersao = `${major
}.${minor
}.${patch
}`;

pkg.version = novaVersao;
fs.writeFileSync(pkgPath, JSON.stringify(pkg,
null,
2) + '\n');
console.log(`✅ package.json atualizado para v${novaVersao
}`);

// 3. Atualizar o index.html (Textos de rodapé e links de Cache)
if (fs.existsSync(indexPath)) {
    let indexHtml = fs.readFileSync(indexPath, 'utf8');

    // Atualiza o texto visual do rodapé (CV Edi Pro vX.Y.Z)
    indexHtml = indexHtml.replace(/CV Edi Pro v\d+\.\d+\.\d+/g, `CV Edi Pro v${novaVersao
  }`);

    // Atualiza o bypass de cache do manifest e service worker
    indexHtml = indexHtml.replace(/manifest\.json\?v=[^"]+/g, `manifest.json?v=${novaVersao}`);
    indexHtml = indexHtml.replace(/sw\.js\?v=[^'
    ] + /g, `sw.js?v=${novaVersao
    }
`);
    
    fs.writeFileSync(indexPath, indexHtml);
    console.log(`✅
index.html atualizado com a v$ {
    novaVersao
    }
e cache limpo.
`);
  } else {
    console.log(`⚠️
index.html não encontrado no caminho / public.
`);
  }

console.log(`🚀
Pronto!Versão $ {
    novaVersao
  }
gerada.Você já pode fazer o commit.
`);